rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if the user is authenticated via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the user is the explicit owner of the private data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // FEATURE: God-Mode Admin Verification
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'testcodecfg@gmail.com';
    }

    // =========================================================================
    // PRODUCTION ARTIFACT ARCHITECTURE (Strict Paths)
    // =========================================================================
    
    match /artifacts/{appId} {
      
      // FEATURE 1: Shared Marketplace Inventory (Events & Tickets)
      // Path: /artifacts/{appId}/public/data/events/{eventId}
      match /public/data/events/{eventId} {
        // Anyone (unauthenticated buyers) can browse the homepage feed and PVR maps
        allow read: if true;
        
        // Only authenticated sellers can create new listings
        allow create: if isAuthenticated();
        
        // Authenticated users can update (e.g., buyers checking out reduces tier stock)
        allow update: if isAuthenticated();
        
        // Only the original seller or admin can delete/archive their own event
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      }

      // FEATURE 2: Transactional Escrow Ledger (Orders)
      // Path: /artifacts/{appId}/public/data/orders/{orderId}
      match /public/data/orders/{orderId} {
        // CRITICAL FIX: Admin bypass injected for God-Mode global read access
        allow read: if isAdmin() || (isAuthenticated() && (
          resource.data.sellerId == request.auth.uid || 
          resource.data.buyerId == request.auth.uid
        ));
        
        // Orders are created by the Main Site (Buyer) upon successful payment
        allow create: if isAuthenticated();
        
        // Strict lockdown: Orders cannot be modified or deleted once created for financial integrity
        allow update, delete: if false;
      }

      // FEATURE 3: Private Seller/Buyer Profiles & Wallet Data
      // Path: /artifacts/{appId}/users/{userId}/...
      match /users/{userId}/{document=**} {
        // Strict ID Matching: Users can only see/edit their own private records. Admins can view for support.
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // =========================================================================
    // FALLBACK SECURITY FOR DIRECT ROOT COLLECTIONS
    // =========================================================================

    match /events/{eventId} {
      allow read: if true;
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    match /orders/{orderId} {
      allow create: if isAuthenticated();
      // CRITICAL FIX: Admin bypass injected for legacy root God-Mode synchronization
      allow read: if isAdmin() || (isAuthenticated() && (
        resource.data.sellerId == request.auth.uid || 
        resource.data.buyerId == request.auth.uid
      ));
      allow update, delete: if false;
    }

    match /users/{userId}/{document=**} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // Catch-all: Deny any rogue access to undefined collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}