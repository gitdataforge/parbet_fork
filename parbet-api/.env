#--- SENDGRID CONFIGURATION ---

#Obtain from SendGrid -> Settings -> API Keys

RESEND_API_KEY=your_sendgrid_api_key_here

#--- FIREBASE ADMIN CONFIGURATION ---

#Go to Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key

#IMPORTANT: This must be the ENTIRE contents of the .json file converted into a single line string

FIREBASE_SERVICE_ACCOUNT={"type": "service_account", "project_id": "parbet-44902", ...}