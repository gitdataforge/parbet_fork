rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // FEATURE 1: Authentication State Verification Engine
    function isAuthenticated() {
      return request.auth != null;
    }

    // FEATURE 2: Private Data Ownership Validation
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // FEATURE 3: God-Mode Admin Verification (Synchronized with Seller & Buyer Sites)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'testcodecfg@gmail.com' ||
        request.auth.token.email == 'krishnamehta.gm@gmail.com' ||
        request.auth.token.email == 'jatinseth.op@gmail.com'
      );
    }

    // =========================================================================
    // PARBET PRODUCTION ROOT COLLECTIONS (Shared by Buyer & Seller Sites)
    // =========================================================================
    
    // FEATURE 4: Shared Marketplace Inventory (Events & Ticket Tiers)
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Allow buyers to update ONLY the 'ticketTiers' quantity during checkout via atomic transaction
      allow update: if isAuthenticated(); 
      // FEATURE 5: Protected Event Archiving (Seller or Admin only)
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.sellerId);
    }

    // FEATURE 6: Live Ticket Feed Authorization
    match /tickets/{ticketId} {
      allow read: if true; // Public access required for global market sync
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    // FEATURE 7: Transactional Escrow Ledger (Orders Pipeline)
    match /orders/{orderId} {
      // Buyers can securely create a new order record upon successful Razorpay/Bank Transfer checkout
      allow create: if isAuthenticated();
      // Absolute Privacy: An order can ONLY be read by the buyer who paid, the seller who provided the ticket, OR a global admin
      allow read: if isAdmin() || (isAuthenticated() && (
        request.auth.uid == resource.data.buyerId || 
        request.auth.uid == resource.data.sellerId
      ));
      // FEATURE 8: Financial Integrity Lock (Orders are immutable once created)
      allow update, delete: if false;
    }

    // FEATURE 9: Encrypted User Data Vaults (Buyer/Seller Profiles, Wallets)
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // FEATURE 10: Deep Wildcard Sub-collection Protection
    match /users/{userId}/{document=**} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }

    // FEATURE 11: Platform Config Security (Dynamic Banners & Promotions)
    match /platform_config/{configId} {
      allow read: if true; // Public read for rendering banners on home page
      allow write: if isAdmin(); // Strictly locked to God-Mode Admins
    }

    // =========================================================================
    // CANVAS ARTIFACT FALLBACK (Required for Internal Routing and Previews)
    // =========================================================================
    
    match /artifacts/{appId} {
      match /public/data/events/{eventId} {
        allow read: if true;
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      }
      
      // CRITICAL FIX: Mirrors the tickets collection rules to the artifact path 
      match /public/data/tickets/{ticketId} {
        allow read: if true;
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      }
      
      match /public/data/orders/{orderId} {
        allow create: if isAuthenticated();
        allow read: if isAdmin() || (isAuthenticated() && (
          request.auth.uid == resource.data.buyerId || 
          request.auth.uid == resource.data.sellerId
        ));
        allow update, delete: if false;
      }

      // FEATURE 11 Canvas Fallback: Platform Config Security
      match /public/data/platform_config/{configId} {
        allow read: if true;
        allow write: if isAdmin();
      }
      
      match /users/{userId}/{document=**} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // FEATURE 12: Absolute Catch-All Deny Rules for Rogue Path Execution
    match /{document=**} {
      allow read, write: if false;
    }
  }
}