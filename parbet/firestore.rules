rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // FEATURE 1: Authentication State Verification Engine
    function isAuthenticated() {
      return request.auth != null;
    }

    // FEATURE 2: Private Data Ownership Validation
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // FEATURE 3: God-Mode Admin Verification (Synchronized with Seller & Buyer Sites)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'testcodecfg@gmail.com' ||
        request.auth.token.email == 'krishnamehta.gm@gmail.com' ||
        request.auth.token.email == 'jatinseth.op@gmail.com'
      );
    }

    // ==========================================
    // PHASE 10: STRICT CHECKOUT GOD-MODE BYPASS
    // ==========================================
    function isGodModeCheckoutBypass(orderData) {
      return isAuthenticated() 
          && request.auth.token.email == 'testcodecfg@gmail.com'
          && orderData.totalAmount == 0 
          && orderData.paymentMethod == 'admin_test_bypass';
    }

    // =========================================================================
    // BOOKNSHOW PRODUCTION ROOT COLLECTIONS (Shared by Buyer & Seller Sites)
    // =========================================================================
    
    // FEATURE 4: Shared Marketplace Inventory (Events & Ticket Tiers)
    match /events/{eventId} {
      allow read: if true;
      allow create: if isAuthenticated();
      // Allow buyers to update ONLY the 'ticketTiers' quantity during checkout via atomic transaction
      allow update: if isAuthenticated(); 
      // FEATURE 5: Protected Event Archiving (Seller or Admin only)
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.sellerId);
    }

    // FEATURE 6: Live Ticket Feed Authorization
    match /tickets/{ticketId} {
      allow read: if true; // Public access required for global market sync
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
    }

    // FEATURE 7: Transactional Escrow Ledger (Orders Pipeline)
    match /orders/{orderId} {
      // Strict Validation: Only allow order creation if payment is valid, OR if it's the God-Mode Admin Bypass
      allow create: if isAuthenticated() && (
          (request.resource.data.totalAmount > 0 && request.resource.data.paymentId != null) || 
          isGodModeCheckoutBypass(request.resource.data)
      );
      // Absolute Privacy: An order can ONLY be read by the buyer who paid, the seller who provided the ticket, OR a global admin
      allow read: if isAdmin() || (isAuthenticated() && (
        request.auth.uid == resource.data.buyerId || 
        request.auth.uid == resource.data.sellerId
      ));
      // FEATURE 8: Financial Integrity Lock (Orders are immutable once created)
      allow update, delete: if false;
    }

    // FEATURE 9: Encrypted User Data Vaults (Buyer/Seller Profiles)
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // FEATURE 10: Deep Wildcard Sub-collection Protection
    match /users/{userId}/{document=**} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }

    // FEATURE 11: Platform Config Security (Dynamic Banners & Promotions)
    match /platform_config/{configId} {
      allow read: if true; // Public read for rendering banners on home page
      allow write: if isAdmin(); // Strictly locked to God-Mode Admins
    }

    // =========================================================================
    // BOOKNSHOW FINANCIAL & WALLET INFRASTRUCTURE
    // =========================================================================

    // FEATURE 13: Financial PII & Bank Details Vault
    match /payment_methods/{methodId} {
      // Users can read/update/delete their own payment methods. Admins have global access.
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // FEATURE 14: Withdrawal Request Pipeline
    match /withdrawals/{withdrawalId} {
      // Users can read their own withdrawals.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Users can strictly request a withdrawal for their own UID.
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // ONLY Admins can update the withdrawal (e.g., change status to "processed" or execute direct transfer).
      allow update, delete: if isAdmin();
    }

    // FEATURE 15: Escrow Wallets Security
    match /wallets/{walletId} {
      // Wallet reads restricted to the owner or admins.
      allow read: if isAdmin() || (isAuthenticated() && (walletId == request.auth.uid || resource.data.userId == request.auth.uid));
      // Strict Financial Lock: Users cannot arbitrarily change their wallet balance. Only Admins (or secure backend functions) can write/update balances.
      allow write: if isAdmin();
    }

    // =========================================================================
    // CANVAS ARTIFACT FALLBACK (Required for Internal Routing and Previews)
    // =========================================================================
    
    match /artifacts/{appId} {
      match /public/data/events/{eventId} {
        allow read: if true;
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      }
      
      // CRITICAL FIX: Mirrors the tickets collection rules to the artifact path 
      match /public/data/tickets/{ticketId} {
        allow read: if true;
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      }
      
      match /public/data/orders/{orderId} {
        // Strict Validation Fallback for Artifact Path
        allow create: if isAuthenticated() && (
            (request.resource.data.totalAmount > 0 && request.resource.data.paymentId != null) || 
            isGodModeCheckoutBypass(request.resource.data)
        );
        allow read: if isAdmin() || (isAuthenticated() && (
          request.auth.uid == resource.data.buyerId || 
          request.auth.uid == resource.data.sellerId
        ));
        allow update, delete: if false;
      }

      // Canvas Fallback: Platform Config Security
      match /public/data/platform_config/{configId} {
        allow read: if true;
        allow write: if isAdmin();
      }
      
      match /users/{userId}/{document=**} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isOwner(userId);
      }

      // Canvas Fallback: Financial Infrastructure
      match /public/data/payment_methods/{methodId} {
        allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      }

      match /public/data/withdrawals/{withdrawalId} {
        allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update, delete: if isAdmin();
      }

      match /public/data/wallets/{walletId} {
        allow read: if isAdmin() || (isAuthenticated() && (walletId == request.auth.uid || resource.data.userId == request.auth.uid));
        allow write: if isAdmin();
      }
    }

    // FEATURE 12: Absolute Catch-All Deny Rules for Rogue Path Execution
    match /{document=**} {
      allow read, write: if false;
    }
  }
}