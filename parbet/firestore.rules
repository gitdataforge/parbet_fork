rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Checks if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the user is the owner of the private user data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // =========================================================================
    // PRODUCTION ARTIFACT ARCHITECTURE (MANDATORY RULE 1)
    // =========================================================================
    
    match /artifacts/{appId} {
      
      // FEATURE 1: Shared Marketplace Data (Tickets)
      // Path: /artifacts/{appId}/public/data/tickets/{docId}
      match /public/data/tickets/{ticketId} {
        // Buyers can read all available tickets to browse the marketplace
        allow read: if true;
        
        // Buyers are STRICTLY FORBIDDEN from creating or modifying tickets
        // Only the Seller (via the Seller Site) can write here
        allow write: if false; 
      }

      // FEATURE 2: Transactional Ledger (Orders)
      // Path: /artifacts/{appId}/public/data/orders/{docId}
      match /public/data/orders/{orderId} {
        // Buyers can create orders when they purchase a ticket
        allow create: if isAuthenticated();
        
        // A user can only read an order if they are the buyer or the seller
        allow read: if isAuthenticated() && (
          request.auth.uid == resource.data.buyerId || 
          request.auth.uid == resource.data.sellerId
        );
        
        // Orders are immutable once created to ensure financial integrity
        allow update, delete: if false;
      }

      // FEATURE 3: Private Buyer Data (Profile, Wallet, Settings)
      // Path: /artifacts/{appId}/users/{userId}/{collectionName}/{docId}
      match /users/{userId}/{collectionName}/{docId} {
        // Strict ID Matching: Users can only see/edit their own private records
        allow read, write: if isOwner(userId);
      }

      // Deep Wildcard Fallback for nested private structures
      match /users/{userId}/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // =========================================================================
    // LEGACY & FALLBACK SECURITY
    // =========================================================================

    // Preserve read access for site banners/assets
    match /site_assets/{assetId} {
      allow read: if true;
      allow write: if false;
    }

    // Catch-all: Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}