rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Checks if the user is authenticated via Firebase Auth
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if the user is the explicit owner of the private data
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // FEATURE: God-Mode Admin Verification (Synchronized with Seller Site)
    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == 'testcodecfg@gmail.com' ||
        request.auth.token.email == 'krishnamehta.gm@gmail.com' ||
        request.auth.token.email == 'jatinseth.op@gmail.com'
      );
    }

    // =========================================================================
    // PARBET PRODUCTION ROOT COLLECTIONS (Shared by Buyer & Seller Sites)
    // =========================================================================
    
    // FEATURE 1: Shared Marketplace Inventory (Events & Ticket Tiers)
    match /events/{eventId} {
      // Allow unrestricted read access so unauthenticated buyers can view the homepage feed
      allow read: if true;
      
      // Strict Gatekeeper: Only authenticated users (Sellers) can list new matches
      // (The specific free-listing bypass is enforced at the application layer)
      allow create: if isAuthenticated();
      
      // Only the seller who created the listing can update it (e.g., deducting inventory after a sale)
      // Allow buyers to update ONLY the 'ticketTiers' quantity during checkout via a transaction
      allow update: if isAuthenticated(); 
      
      // Only the specific seller or any global admin can delete/archive their event
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.sellerId);
    }

    // FEATURE 2: Transactional Escrow Ledger (Orders)
    match /orders/{orderId} {
      // Buyers can securely create a new order record upon successful Razorpay/Bank Transfer checkout
      allow create: if isAuthenticated();
      
      // Absolute Privacy: An order can ONLY be read by the buyer who paid, the seller who provided the ticket, OR a global admin
      allow read: if isAdmin() || (isAuthenticated() && (
        request.auth.uid == resource.data.buyerId || 
        request.auth.uid == resource.data.sellerId
      ));
      
      // Financial Integrity: Orders are immutable once created by the buyer
      allow update, delete: if false;
    }

    // FEATURE 3: Private User Data (Buyer/Seller Profiles, Wallets, Settings)
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }
    
    // Deep Wildcard Fallback for nested private structures inside a user's profile
    match /users/{userId}/{document=**} {
      allow read: if isAdmin() || isOwner(userId);
      allow write: if isOwner(userId);
    }

    // =========================================================================
    // CANVAS ARTIFACT FALLBACK (Required for Immersive Previews)
    // =========================================================================
    
    match /artifacts/{appId} {
      match /public/data/events/{eventId} {
        allow read: if true;
        allow create, update: if isAuthenticated();
        allow delete: if isAdmin() || (isAuthenticated() && resource.data.sellerId == request.auth.uid);
      }
      match /public/data/orders/{orderId} {
        allow create: if isAuthenticated();
        allow read: if isAdmin() || (isAuthenticated() && (
          request.auth.uid == resource.data.buyerId || 
          request.auth.uid == resource.data.sellerId
        ));
        allow update, delete: if false;
      }
      match /users/{userId}/{document=**} {
        allow read: if isAdmin() || isOwner(userId);
        allow write: if isOwner(userId);
      }
    }

    // Catch-all: Deny any rogue access to undefined collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}